{
    "name": "Renewable_Service",
    "esdl_type": "PVInstallation",
    "description": "Simulates solar generation and handles curtailment.",
    "relevant_links": [],
    "calculations": [
        {
            "name": "day_ahead_renewables",
            "description": "Forecasts generation for the next day.",
            "time_period_in_seconds": 86400,
            "offset_in_seconds": 0,
            "inputs": [],
            "outputs": [
                {
                    "name": "planned_generation_DA",
                    "data_type": "STRING",
                    "description": "JSON string of forecasted solar generation.",
                    "unit": "JSON"
                }
            ]
        },
        {
            "name": "real_time_renewables",
            "time_period_in_seconds" : 900,
            "offset_in_seconds" : 0,
            "description": "Calculates actual power subject to EMS constraints.",
            "inputs": [
                {
                    "name": "current_max_power_limit",
                    "esdl_type": "ElectricityNetwork",
                    "data_type": "DOUBLE",
                    "description": "Curtailment limit from EMS.",
                    "unit": "W"
                }
            ],
            "outputs": [
                {
                    "name": "potential_available_generation_ID",
                    "data_type": "DOUBLE",
                    "description": "Maximum generation possible from weather.",
                    "unit": "W"
                },
                {
                    "name": "supplied_power_ID",
                    "data_type": "DOUBLE",
                    "description": "Actual generation after curtailment.",
                    "unit": "W"
                }
            ]
        }
    ]
}